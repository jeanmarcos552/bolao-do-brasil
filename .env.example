# === Firebase (cliente) — publicas, inlinadas no bundle em build-time ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === WebSocket ao vivo (ws.jeansilva.app.br) ===
# URL publica que o cliente conecta (build-time):
NEXT_PUBLIC_WS_URL=
# Endpoint de publish server->WS e a API key (runtime, servidor — NAO publicas):
WS_PUBLISH_URL=
WS_API_KEY=

# === Firebase Admin (servidor) — SECRETOS, so em runtime ===
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# === App ===
ADMIN_EMAILS=jean.silva@b2agencia.com.br
# Porta do servidor Next. Dev: 3000. Deploy (bolao.jeansilva.app.br): 3002.
PORT=3000
